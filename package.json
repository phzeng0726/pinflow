{
  "name": "pinflow",
  "version": "0.1.0",
  "description": "Trello-style kanban with desktop pin overlay",
  "main": "electron/main.js",
  "author": "PinFlow",
  "license": "MIT",
  "scripts": {
    "postinstall": "node scripts/patch-rcedit.js",
    "electron:dev": "cross-env ELECTRON_DEV=1 electron .",
    "electron:build:frontend": "cross-env ELECTRON_BUILD=1 pnpm --filter frontend build",
    "electron:package": "scripts\\build.bat"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.pinflow.app",
    "productName": "PinFlow",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "!electron/resources/**",
      "frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/resources/",
        "to": ".",
        "filter": [
          "pinflow-backend*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icons/icon.png"
    }
  }
}
